# GLOBAL SETTINGS

APP_NAME=DTS API
APP_DESCRIPTION=A simple API to serve TEI XML documents as JSON-LD, following the Distributed Text Services specifications.
APP_AUTHOR_INFOS='{"name": ": Your Name", "email": "your@email.com"}'
APP_URL=[{"url": "http://127.0.0.1:8000", "description": "Localhost"}]

DTS_CONTEXT='https://distributed-text-services.github.io/specifications/context/1-alpha1.json'
DTS_VERSION='1-alpha'
APP_VERSION='1.0.0'
ROOT_COLLECTION='1'
TESTING='true' # set to true to run tests

# DATABASE SETTINGS
STORAGE='local' # available : local, exist, github
INDEXER='standard' # available : standard, pta

# local storage
BASE_PATH="dummy/local-storage-data/database"
METADATA_PATH="metadata.json"

# XML SETTINGS
TEI_NS='http://www.tei-c.org/ns/1.0'